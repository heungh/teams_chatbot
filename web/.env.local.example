# 일반적 사용: 모든 동적 값은 SSM Parameter Store /teams-bedrock-chatbot/* 에서 자동 로드.
# AWS_REGION 만 명시하면 충분합니다.

AWS_REGION=us-west-2

# ============================================================
# (선택) 환경변수로 SSM 을 override — 로컬 테스트 / CI 용
# ============================================================
# 하나라도 설정하면 그 값은 env 가 우선됩니다.
# KB_ID=<your-kb-id>
# MODEL_ID=us.anthropic.claude-sonnet-4-6     # inference profile 사용 시 AWS_ACCOUNT_ID 필요
# AWS_ACCOUNT_ID=<your-aws-account-id>        # 미설정 시 STS GetCallerIdentity 자동 호출
# PARAM_PREFIX=/teams-bedrock-chatbot         # 기본 prefix 변경 시
# AWS_PROFILE=your-profile                    # 다른 자격 증명 프로필
